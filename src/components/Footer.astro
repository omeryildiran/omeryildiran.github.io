---
import { site } from "../site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container wide inner">
    <div class="left">
      <div class="title notranslate" translate="no">{site.name}</div>
      <div class="meta">
        <span>{site.location}</span>
        <span aria-hidden="true">·</span>
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </div>
    </div>
    <div class="right">
      <a class="chip" href="/notes/">Notes</a>
      <a class="chip" href="/projects/">Projects</a>
      <a class="chip" href="/publications/">Publications</a>
      <span class="copy">© {year}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer{
    margin-top: 3.2rem;
    padding: 1.6rem 0 2.1rem;
    border-top: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
  }
  .inner{
    display:flex;
    align-items:flex-end;
    justify-content:space-between;
    gap: 1rem;
  }
  .title{ font-weight: 650; letter-spacing: -0.01em; }
  .meta{
    color: var(--muted);
    display:flex;
    gap: .5rem;
    flex-wrap: wrap;
    font-size: .95rem;
  }
  .right{
    display:flex;
    align-items:center;
    gap: .5rem;
    flex-wrap: wrap;
    justify-content:flex-end;
  }
  .chip{
    border: 1px solid var(--border);
    background: var(--surface);
    padding: .35rem .6rem;
    border-radius: 999px;
    color: var(--text);
    text-decoration:none;
    font-size: .92rem;
  }
  .chip:hover{ text-decoration:none; filter: brightness(.99); }
  .copy{ color: var(--muted); font-size: .92rem; }
  @media (max-width: 760px){
    .inner{ flex-direction: column; align-items:flex-start; }
    .right{ justify-content:flex-start; }
  }
</style>
