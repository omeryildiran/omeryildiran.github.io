---
const nav = [
  { href: "/", label: "Home" },
  { href: "/about/", label: "About" },
  { href: "/publications/", label: "Publications" },
  { href: "/projects/", label: "Projects" },
  { href: "/movies/", label: "Movies" },
  { href: "/notes/", label: "Notes" },
  { href: "/cv/", label: "CV" },
  { href: "/contact/", label: "Contact" }
];
---

<header class="site-header">
  <div class="container wide inner">
    <a class="brand" href="/" aria-label="Homepage">
      <span class="dot" aria-hidden="true"></span>
      <span class="name notranslate" translate="no"><slot name="name" /></span>
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((item) => (
        <a class="navlink" href={item.href}>
          {item.label}
        </a>
      ))}

      <div class="translate-toggle" role="group" aria-label="Language switcher">
        <button
          class="translate-toggle__button notranslate"
          type="button"
          data-translate-button="en"
          aria-pressed="true"
          translate="no"
        >
          EN
        </button>
        <button
          class="translate-toggle__button notranslate"
          type="button"
          data-translate-button="tr"
          aria-pressed="false"
          translate="no"
        >
          TR
        </button>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header{
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border-bottom: 1px solid var(--border);
  }
  .inner{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding: .85rem 0;
    gap: 1rem;
  }
  .brand{
    display:flex;
    align-items:center;
    gap: .65rem;
    font-weight: 650;
    color: var(--text);
    text-decoration:none;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .dot{
    width: 11px;
    height: 11px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--brand), var(--brand-2));
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--brand) 16%, transparent);
  }
  .name{ font-size: 1.02rem; }
  .nav{
    display:flex;
    flex-wrap: wrap;
    gap: .25rem .35rem;
    justify-content: flex-end;
  }
  .navlink{
    color: color-mix(in srgb, var(--text) 86%, var(--muted) 14%);
    padding: .45rem .65rem;
    border-radius: 999px;
    border: 1px solid transparent;
    text-decoration:none;
    font-size: .95rem;
  }
  .navlink:hover{
    border-color: var(--border);
    background: var(--surface);
    text-decoration:none;
  }
  .translate-toggle{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 90%, transparent);
    padding: .2rem;
  }
  .translate-toggle__button{
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    font-size: .88rem;
    font-weight: 700;
    letter-spacing: .06em;
    line-height: 1;
    cursor: pointer;
    padding: .32rem .62rem;
    border-radius: 999px;
    opacity: .65;
    transition: background .2s ease, color .2s ease, opacity .2s ease;
  }
  .translate-toggle__button:hover{
    opacity: 1;
  }
  .translate-toggle__button[aria-pressed="true"]{
    background: linear-gradient(135deg, var(--brand), var(--brand-2));
    color: white;
    opacity: 1;
  }
  @media (max-width: 760px){
    .inner{ align-items:flex-start; flex-direction: column; }
    .nav{ justify-content: flex-start; }
  }
</style>
