---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projectDemos, researchProjects } from "../../data/projects";
---

<BaseLayout title="Projects" description="Research projects, demos, and tooling." wide>
  <h1>Projects</h1>
  <p>
    A selection of my research projects across perception, cognitive science, and computational modeling.
  </p>

  <section class="section">
    <h2>Research</h2>
    <div class="research">
      {researchProjects.map((p) => (
        <article class="r-card card">
          <h3 class="r-title">
            <span class="icon" aria-hidden="true">{p.icon}</span>
            {p.title}
          </h3>
          <p class="r-desc">{p.description}</p>
          <ul class="r-bullets">
            {p.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Demos</h2>
    <div class="demos">
      {projectDemos.map((p) => (
        <article class="demo card">
          <h3 class="demo-title">{p.title}</h3>
          {p.chips?.length ? (
            <div class="chips">
              {p.chips.map((c) => (
                <a class="chip" href={c.href}>{c.label}</a>
              ))}
            </div>
          ) : null}
          <div class="media">
            {p.embed.kind === "iframe" ? (
              <iframe
                class="frame"
                src={p.embed.src}
                title={p.embed.title}
                allow={p.embed.allow}
                allowfullscreen
              />
            ) : (
              <img class="img" src={p.embed.src} alt={p.embed.alt} loading="lazy" />
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .section{ margin-top: 1.4rem; }

  .research{
    display:grid;
    grid-template-columns: repeat(2, 1fr);
    gap: .9rem;
    margin-top: .9rem;
  }
  .r-card{ padding: 1rem 1.05rem 1.05rem; }
  .r-title{
    margin: .1rem 0 .35rem;
    display:flex;
    align-items:center;
    gap: .55rem;
    font-size: 1.12rem;
  }
  .icon{
    width: 28px; height: 28px;
    display:grid; place-items:center;
    border-radius: 10px;
    background: color-mix(in srgb, var(--surface) 86%, #eef2ff 14%);
    border: 1px solid var(--border);
  }
  .r-desc{ margin: 0 0 .6rem; color: var(--muted); }
  .r-bullets{ margin: 0; padding-left: 1.15rem; color: var(--muted); }

  .demos{
    display:grid;
    grid-template-columns: repeat(2, 1fr);
    gap: .9rem;
    margin-top: .9rem;
  }
  .demo{ padding: 1rem; }
  .demo-title{ margin: .1rem 0 .6rem; font-size: 1.12rem; }
  .chips{ display:flex; flex-wrap: wrap; gap:.4rem; margin-bottom: .75rem; }
  .chip{
    border: 1px solid var(--border);
    background: var(--surface);
    padding: .32rem .6rem;
    border-radius: 999px;
    color: var(--text);
    text-decoration:none;
    font-size: .92rem;
  }
  .chip:hover{ text-decoration:none; filter: brightness(.99); }
  .media{
    border-radius: 12px;
    overflow:hidden;
    border: 1px solid var(--border);
    background: #000;
  }
  .frame{
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    display:block;
  }
  .img{
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display:block;
    background: #000;
  }
  @media (max-width: 980px){
    .research{ grid-template-columns: 1fr; }
    .demos{ grid-template-columns: 1fr; }
  }
</style>

