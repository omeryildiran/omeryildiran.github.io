    .grid{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .map{ min-height: 220px; }
  }
</style>

<link rel="stylesheet" href="https://unpkg.com/svgmap@latest/dist/svgMap.min.css" />

<script>
  const grid = document.getElementById("grid");
  const items = Array.from(grid.querySelectorAll(".movie"));
  const view = document.getElementById("view");
  const q = document.getElementById("q");
  const minRating = document.getElementById("minRating");
  const yearMin = document.getElementById("yearMin");
  const yearMax = document.getElementById("yearMax");
  const month = document.getElementById("month");
  const sort = document.getElementById("sort");
  const count = document.getElementById("count");
  const mapEl = document.getElementById("map");
  const clearCountry = document.getElementById("clearCountry");
  const countryLabel = document.getElementById("countryLabel");

  let selectedCountry = "";

  function num(v) {
    const n = Number(v);
    return Number.isFinite(n) ? n : null;
  }

  function apply() {
    const viewMode = view.value;
    const query = (q.value || "").trim().toLowerCase();
    const minR = minRating.value ? Number(minRating.value) : null;
    const yMin = num(yearMin.value) ?? Number(grid.dataset.minyear);
    const yMax = num(yearMax.value) ?? Number(grid.dataset.maxyear);
    const monthVal = month.value || "";

    let visible = items.filter((el) => {
      const title = el.dataset.title || "";
      const year = num(el.dataset.year);
      const rating = num(el.dataset.rating);
      const diaryRated = el.dataset.diary === "1";
      const mth = el.dataset.month || "";
      const countries = (el.dataset.countries || "").split(",").filter(Boolean);

      if (viewMode === "diary" && !diaryRated) return false;
      if (selectedCountry && !countries.includes(selectedCountry)) return false;
      if (query && !title.includes(query)) return false;
      if (minR != null && (rating == null || rating < minR)) return false;
      if (year != null && (year < yMin || year > yMax)) return false;
      if (monthVal && mth !== monthVal) return false;
      return true;
    });

    const key = sort.value;
    const cmp = {
      watched_desc: (a, b) => (b.dataset.watched || "").localeCompare(a.dataset.watched || ""),
      watched_asc: (a, b) => (a.dataset.watched || "").localeCompare(b.dataset.watched || ""),
      rating_desc: (a, b) => (num(b.dataset.rating) ?? -1) - (num(a.dataset.rating) ?? -1),
      rating_asc: (a, b) => (num(a.dataset.rating) ?? 99) - (num(b.dataset.rating) ?? 99),
      title_asc: (a, b) => (a.dataset.title || "").localeCompare(b.dataset.title || ""),
      title_desc: (a, b) => (b.dataset.title || "").localeCompare(a.dataset.title || ""),
      year_desc: (a, b) => (num(b.dataset.year) ?? -1) - (num(a.dataset.year) ?? -1),
      year_asc: (a, b) => (num(a.dataset.year) ?? 9999) - (num(b.dataset.year) ?? 9999)
    }[key];

    visible.sort(cmp);

    // Hide all, then append visible in sorted order.
    items.forEach((el) => (el.style.display = "none"));
    visible.forEach((el) => {
      el.style.display = "";
      grid.appendChild(el);
    });

    count.textContent = `${visible.length} / ${items.length} movies`;
  }

  function buildCountryCounts() {
    const counts = new Map();
    items.forEach((el) => {
      const list = (el.dataset.countries || "").split(",").filter(Boolean);
      list.forEach((c) => counts.set(c, (counts.get(c) ?? 0) + 1));
    });
    const values = {};
    // Use svgMap's built-in `link` handling for clicks. We'll read the hash and
    // apply filtering on `hashchange`.
    counts.forEach((n, c) => {
      values[c] = { total: n, link: `#country=${encodeURIComponent(c)}` };
    });
    return values;
  }

  function setSelectedCountry(code) {
    selectedCountry = code || "";
    countryLabel.textContent = selectedCountry ? `Country: ${selectedCountry}` : "";
    apply();
  }

  function syncCountryFromHash() {
    const m = (location.hash || "").match(/(?:^|#)country=([A-Z]{2})/);
    setSelectedCountry(m?.[1] ?? "");
  }

  function initMap() {
    if (!mapEl) return;
    const values = buildCountryCounts();
    const create = () => {
      if (!window.svgMap) return;
      // eslint-disable-next-line no-new
      new window.svgMap({
        targetElementID: "map",
        colorMin: "#93c5fd",
        colorMax: "#1d4ed8",
        colorNoData: "#e2e8f0",
        touchLink: true,
        data: {
          data: { total: { name: "Movies" } },
          applyData: "total",
          values
        }
      });
    };

    if (window.svgMap) {
      create();
      return;
    }

    const existing = document.querySelector('script[data-svgmap="1"]');
    if (existing) {
      existing.addEventListener("load", create, { once: true });
      return;
    }

    const s = document.createElement("script");
    s.src = "https://unpkg.com/svgmap@latest/dist/svgMap.min.js";
    s.async = true;
    s.dataset.svgmap = "1";
    s.addEventListener("load", create, { once: true });
    document.head.appendChild(s);
  }

  [view, q, minRating, yearMin, yearMax, month, sort].forEach((el) =>
    el.addEventListener("input", apply)
  );

  clearCountry?.addEventListener("click", () => {
    history.replaceState(null, "", location.pathname + location.search);
    syncCountryFromHash();
  });

  window.addEventListener("hashchange", syncCountryFromHash);

  initMap();
  syncCountryFromHash();
  apply();
</script>
