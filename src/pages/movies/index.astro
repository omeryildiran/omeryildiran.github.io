---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fs from "node:fs/promises";
import path from "node:path";
import posterCache from "../../data/letterboxd-posters.json";
import countriesCache from "../../data/letterboxd-countries.json";

const diaryPath = path.resolve(
  process.cwd(),
  "use_these_ai/letterboxd_export_oyildiran/diary.csv"
);
const watchedPath = path.resolve(
  process.cwd(),
  "use_these_ai/letterboxd_export_oyildiran/watched.csv"
);
const diaryCsv = await fs.readFile(diaryPath, "utf-8");
const watchedCsv = await fs.readFile(watchedPath, "utf-8");

function parseCsv(text) {
  // Minimal CSV parser for Letterboxd exports (handles quoted commas).
  const rows = [];
  let row = [];
  let field = "";
  let inQuotes = false;

  for (let i = 0; i < text.length; i++) {
    const c = text[i];
    const next = text[i + 1];

    if (c === '"' && inQuotes && next === '"') {
      field += '"';
      i++;
      continue;
    }
    if (c === '"') {
      inQuotes = !inQuotes;
      continue;
    }
    if (!inQuotes && (c === "," || c === "\n" || c === "\r")) {
      if (c === "\r" && next === "\n") continue;
      row.push(field);
      field = "";
      if (c === "\n") {
        if (row.length > 1 || row[0] !== "") rows.push(row);
        row = [];
      }
      continue;
    }
    field += c;
  }
  row.push(field);
  if (row.length > 1 || row[0] !== "") rows.push(row);
  return rows;
}

function buildFromDiary(csvText) {
  const rows = parseCsv(csvText);
  const header = rows[0] ?? [];
  const idx = (name) => header.indexOf(name);

  return rows
    .slice(1)
    .map((r) => ({
      name: r[idx("Name")] ?? "",
      year: Number(r[idx("Year")] ?? "") || null,
      letterboxdUri: r[idx("Letterboxd URI")] ?? "",
      rating: r[idx("Rating")] ? Number(r[idx("Rating")]) : null,
      watchedDate: r[idx("Watched Date")] ?? ""
    }))
    .filter((m) => m.name);
}

function buildFromWatched(csvText) {
  const rows = parseCsv(csvText);
  const header = rows[0] ?? [];
  const idx = (name) => header.indexOf(name);

  return rows
    .slice(1)
    .map((r) => ({
      name: r[idx("Name")] ?? "",
      year: Number(r[idx("Year")] ?? "") || null,
      letterboxdUri: r[idx("Letterboxd URI")] ?? "",
      rating: null,
      watchedDate: r[idx("Date")] ?? ""
    }))
    .filter((m) => m.name);
}

const diaryMoviesRaw = buildFromDiary(diaryCsv);
const watchedMoviesRaw = buildFromWatched(watchedCsv);

const posterDir = path.resolve(process.cwd(), "public/assets/movies/posters");

function normalizeUri(uri) {
  return (uri ?? "").trim().replace(/\/+$/g, "");
}

async function posterFor(letterboxdUri) {
  const normalized = normalizeUri(letterboxdUri);
  const id = (normalized ?? "").trim().split("/").filter(Boolean).pop() ?? "";
  if (!id) return { id: "", poster: null };
  const candidate = path.join(posterDir, `${id}.jpg`);
  try {
    await fs.access(candidate);
    return { id, poster: `/assets/movies/posters/${id}.jpg` };
  } catch {
    // Cache keys in `letterboxd-posters.json` may or may not include trailing slashes.
    const cached = posterCache?.[normalized] ?? posterCache?.[letterboxdUri] ?? null;
    return { id, poster: cached };
  }
}

function countrySlugsFor(letterboxdUri) {
  const normalized = normalizeUri(letterboxdUri);
  const rec = countriesCache?.[normalized] ?? countriesCache?.[letterboxdUri] ?? null;
  const codes = rec?.countryCodes ?? [];
  if (Array.isArray(codes) && codes.length) return codes;
  const slugs = rec?.countries ?? [];
  return Array.isArray(slugs) ? slugs : [];
}

// Diary should behave like a filter on top of watched.
// In your exports, `Letterboxd URI` can differ between `watched.csv` and `diary.csv`
// even for the same movie, so we key by `Name + Year` instead.
function movieKey(m) {
  const name = (m.name ?? "").trim().toLowerCase();
  const year = m.year ?? "";
  return name ? `${name}|${year}` : "";
}

function toIsoDate(s) {
  const v = (s ?? "").trim();
  if (!v) return "";
  // Already ISO
  if (/^\d{4}-\d{2}-\d{2}$/.test(v)) return v;
  // Common US export formats: M/D/YY, M/D/YYYY
  const m = v.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2}|\d{4})$/);
  if (m) {
    const mm = Number(m[1]);
    const dd = Number(m[2]);
    const yyRaw = m[3];
    const yyyy =
      yyRaw.length === 4 ? Number(yyRaw) : 2000 + Number(yyRaw); // assume 20xx
    if (
      Number.isFinite(mm) &&
      Number.isFinite(dd) &&
      Number.isFinite(yyyy) &&
      mm >= 1 &&
      mm <= 12 &&
      dd >= 1 &&
      dd <= 31
    ) {
      return `${String(yyyy).padStart(4, "0")}-${String(mm).padStart(2, "0")}-${String(dd).padStart(2, "0")}`;
    }
  }
  return "";
}

const diaryByKey = new Map();
for (const m of diaryMoviesRaw) {
  const key = movieKey(m);
  if (!key) continue;
  diaryByKey.set(key, {
    rating: m.rating,
    watchedDate: m.watchedDate ?? "",
    watchedDateIso: toIsoDate(m.watchedDate ?? "")
  });
}

const watchedByKey = new Map();
for (const m of watchedMoviesRaw) {
  const key = movieKey(m);
  if (!key) continue;
  const prev = watchedByKey.get(key);
  if (!prev) {
    watchedByKey.set(key, m);
    continue;
  }
  // If there are multiple watched rows per title/year (unlikely), keep the one
  // with the most recent watched date for sorting.
  const prevIso = toIsoDate(prev.watchedDate ?? "");
  const nextIso = toIsoDate(m.watchedDate ?? "");
  if (nextIso && nextIso >= prevIso) watchedByKey.set(key, m);
}

const movies = await Promise.all(
  Array.from(watchedByKey.values()).map(async (m) => {
    const key = movieKey(m);
    const diary = diaryByKey.get(key);
    const { id, poster } = await posterFor(m.letterboxdUri);
    const watchedDisplay = diary?.watchedDate || m.watchedDate || "";
    const watchedIso = diary?.watchedDateIso || toIsoDate(m.watchedDate ?? "");
    const countries = countrySlugsFor(m.letterboxdUri);
    return {
      ...m,
      id,
      poster,
      rating: diary ? diary.rating : null,
      watchedDate: watchedDisplay,
      watchedDateIso: watchedIso,
      countries,
      diaryRated: diary?.rating != null
    };
  })
);

// Sort server-side so the initial HTML is correct even before JS runs.
// Important: do NOT use rating for ordering.
movies.sort((a, b) => {
  const wd = (b.watchedDateIso || "").localeCompare(a.watchedDateIso || "");
  if (wd) return wd;
  const yd = (b.year ?? -1) - (a.year ?? -1);
  if (yd) return yd;
  return (a.name || "").localeCompare(b.name || "");
});

const years = movies.map((m) => m.year).filter(Boolean);
const minYear = years.length ? Math.min(...years) : 1900;
const maxYear = years.length ? Math.max(...years) : new Date().getFullYear();

const months = Array.from(
  new Set(
    movies
      .map((m) => (m.watchedDateIso || "").slice(0, 7))
      .filter((x) => /^\d{4}-\d{2}$/.test(x))
  )
).sort((a, b) => b.localeCompare(a));

const favoriteMovies = movies
  .filter((m) => m.rating != null)
  .sort((a, b) => {
    const ratingDiff = (b.rating ?? -1) - (a.rating ?? -1);
    if (ratingDiff) return ratingDiff;
    const watchedDiff = (b.watchedDateIso || "").localeCompare(a.watchedDateIso || "");
    if (watchedDiff) return watchedDiff;
    return (a.name || "").localeCompare(b.name || "");
  })
  .slice(0, 5);
---

<BaseLayout title="Watched movies" description="My watched movies (Letterboxd export)." wide>
  <h1>Watched movies</h1>

  <section class="hero">
    <div class="card favoritesWrap">
      <div class="sectionHead">
        <div>
          <div class="sectionTitle">Favorite 5</div>
          <div class="sectionSub">A quick way to show taste before the full archive.</div>
        </div>
        <a class="btn primary jumpBtn" href="#all-movies">Browse all movies</a>
      </div>

      <div class="favoritesGrid">
        {favoriteMovies.map((m, index) => (
          <article class="favoriteCard">
            <a class="favoritePoster" href={m.letterboxdUri} target="_blank" rel="noopener">
              {m.poster ? (
                <img loading="lazy" src={m.poster} alt={`${m.name} poster`} />
              ) : (
                <div class="placeholder favoritePlaceholder" aria-hidden="true">
                  <span>{(m.name[0] ?? "•").toUpperCase()}</span>
                </div>
              )}
            </a>
            <div class="favoriteInfo">
              <div class="favoriteKicker">#{index + 1} favorite</div>
              <div class="favoriteTitle" title={m.name}>{m.name}</div>
              <div class="favoriteMeta">
                <span>{m.year ?? "—"}</span>
                <span class="dot" aria-hidden="true">·</span>
                <span>{m.rating ?? "—"} ★</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="card mapWrap">
      <div class="sectionHead mapHeader">
        <div>
          <div class="sectionTitle">Filter by country</div>
          <div class="sectionSub">Use the map to narrow the list below.</div>
        </div>
        <button id="clearCountry" class="btn" type="button">Clear</button>
      </div>
      <div id="map" class="map"></div>
      <div class="mapMeta">
        <span id="countryLabel"></span>
        <span class="legend">Darker countries mean more watched movies.</span>
      </div>
    </div>
  </section>


  <div class="controls card">
    <div class="row">
      <label class="field">
        <span>View</span>
        <select id="view">
          <option value="watched" selected>Watched (all)</option>
          <option value="diary">Diary (rated entries)</option>
        </select>
      </label>

      <label class="field">
        <span>Search</span>
        <input id="q" type="search" placeholder="Title…" />
      </label>

      <label class="field">
        <span>Min rating</span>
        <select id="minRating">
          <option value="">Any</option>
          <option value="0.5">0.5+</option>
          <option value="1">1+</option>
          <option value="1.5">1.5+</option>
          <option value="2">2+</option>
          <option value="2.5">2.5+</option>
          <option value="3">3+</option>
          <option value="3.5">3.5+</option>
          <option value="4">4+</option>
          <option value="4.5">4.5+</option>
          <option value="5">5</option>
        </select>
      </label>

      <label class="field">
        <span>Year</span>
        <div class="year">
          <input id="yearMin" type="number" inputmode="numeric" min={minYear} max={maxYear} value={minYear} />
          <span class="sep">–</span>
          <input id="yearMax" type="number" inputmode="numeric" min={minYear} max={maxYear} value={maxYear} />
        </div>
      </label>

      <label class="field">
        <span>Month</span>
        <select id="month">
          <option value="">Any</option>
          {months.map((m) => (
            <option value={m}>{m}</option>
          ))}
        </select>
      </label>

      <label class="field">
        <span>Sort</span>
        <select id="sort">
          <option value="watched_desc">Watched date ↓</option>
          <option value="watched_asc">Watched date ↑</option>
          <option value="rating_desc">Rating ↓</option>
          <option value="rating_asc">Rating ↑</option>
          <option value="title_asc">Title A→Z</option>
          <option value="title_desc">Title Z→A</option>
          <option value="year_desc">Year ↓</option>
          <option value="year_asc">Year ↑</option>
        </select>
      </label>
    </div>

    <div class="meta">
      <span id="count"></span>
    </div>
  </div>

  <div id="all-movies" class="listHeader">
    <div>
      <div class="sectionTitle">All movies</div>
      <div class="sectionSub">Filtered results update instantly from the controls and map.</div>
    </div>
  </div>

  <div id="grid" class="grid" data-minyear={minYear} data-maxyear={maxYear}>
    {movies.map((m) => (
      <article
        class="movie card"
        data-title={m.name.toLowerCase()}
        data-year={m.year ?? ""}
        data-rating={m.rating ?? ""}
        data-watched={m.watchedDateIso ?? ""}
        data-month={(m.watchedDateIso ?? "").slice(0, 7)}
        data-diary={m.diaryRated ? "1" : ""}
        data-countries={(m.countries ?? []).join(",")}
      >
        <a class="poster" href={m.letterboxdUri} target="_blank" rel="noopener">
          {m.poster ? (
            <img loading="lazy" src={m.poster} alt={`${m.name} poster`} />
          ) : (
            <div class="placeholder" aria-hidden="true">
              <span>{(m.name[0] ?? "•").toUpperCase()}</span>
            </div>
          )}
        </a>
        <div class="info">
          <div class="title" title={m.name}>{m.name}</div>
          <div class="sub">
            <span>{m.year ?? "—"}</span>
            <span class="dot" aria-hidden="true">·</span>
            <span>{m.rating ?? "—"} ★</span>
          </div>
          <div class="watched">
            Watched: <span class="mono">{m.watchedDate || "—"}</span>
          </div>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>

