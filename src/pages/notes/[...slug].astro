---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((n) => ({
    params: { slug: n.data.slug ?? n.slug },
    props: { note: n }
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
---

<BaseLayout
  title={`${note.data.title} · Notes`}
  description={note.data.description ?? "Note"}
>
  <article>
    <p class="meta">
      <time datetime={note.data.date.toISOString()}>
        {note.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "2-digit"
        })}
      </time>
      {note.data.tags?.length ? (
        <span class="tags">
          {note.data.tags.map((t) => (
            <span class="tag">{t}</span>
          ))}
        </span>
      ) : null}
    </p>
    <h1>{note.data.title}</h1>
    <Content />
  </article>
</BaseLayout>

<style>
  .meta{
    margin: 0 0 .65rem;
    display:flex;
    align-items:center;
    gap: .6rem;
    flex-wrap: wrap;
    color: var(--muted);
    font-size: .95rem;
  }
  .tags{ display:flex; gap:.35rem; flex-wrap: wrap; }
  .tag{
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 86%, #eef2ff 14%);
    padding: .15rem .45rem;
    border-radius: 999px;
    font-size: .85rem;
    color: color-mix(in srgb, var(--text) 86%, var(--muted) 14%);
  }
</style>

