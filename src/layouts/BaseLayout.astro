---
import "../styles/global.css";
import "../styles/katex.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../site";

type Props = {
  title?: string;
  description?: string;
  wide?: boolean;
};

const {
  title = site.name,
  description = site.description,
  wide = false
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="google" content="notranslate" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} RSS`} href="/rss.xml" />
  </head>
  <body>
    <div id="google_translate_element" class="translate-widget" aria-hidden="true"></div>

    <Header>
      <span slot="name">{site.name}</span>
    </Header>

    <main class:list={["main", wide ? "wide" : ""]}>
      <div class:list={["container", "prose", wide ? "wide" : ""]}>
        <slot />
      </div>
    </main>

    <Footer />

    <script is:inline>
      const TRANSLATE_SESSION_KEY = "translate-language";
      const SOURCE_LANGUAGE = "en";
      const TARGET_LANGUAGE = "tr";

      function setTranslateCookie(language) {
        const value = language === TARGET_LANGUAGE
          ? `/${SOURCE_LANGUAGE}/${TARGET_LANGUAGE}`
          : `/${SOURCE_LANGUAGE}/${SOURCE_LANGUAGE}`;

        document.cookie = `googtrans=${value};path=/`;

        if (window.location.hostname.includes(".")) {
          document.cookie = `googtrans=${value};domain=${window.location.hostname};path=/`;
        }
      }

      function getTranslateCookie() {
        const match = document.cookie.match(/(?:^|;\s*)googtrans=([^;]+)/);
        return match ? decodeURIComponent(match[1]) : "";
      }

      function getCurrentLanguage() {
        return getTranslateCookie().includes(`/${SOURCE_LANGUAGE}/${TARGET_LANGUAGE}`)
          ? TARGET_LANGUAGE
          : SOURCE_LANGUAGE;
      }

      function setSessionLanguage(language) {
        try {
          window.sessionStorage.setItem(TRANSLATE_SESSION_KEY, language);
        } catch {}
      }

      function getSessionLanguage() {
        try {
          return window.sessionStorage.getItem(TRANSLATE_SESSION_KEY);
        } catch {
          return null;
        }
      }

      function updateToggle(language) {
        const enButton = document.querySelector('[data-translate-button="en"]');
        const trButton = document.querySelector('[data-translate-button="tr"]');

        if (enButton instanceof HTMLButtonElement) {
          enButton.setAttribute("aria-pressed", String(language !== TARGET_LANGUAGE));
        }

        if (trButton instanceof HTMLButtonElement) {
          trButton.setAttribute("aria-pressed", String(language === TARGET_LANGUAGE));
        }
      }

      function applyLanguage(language, options = {}) {
        const nextLanguage = language === TARGET_LANGUAGE ? TARGET_LANGUAGE : SOURCE_LANGUAGE;
        const shouldReload = options.reload === true;

        setTranslateCookie(nextLanguage);
        document.documentElement.lang = SOURCE_LANGUAGE;
        updateToggle(nextLanguage);

        if (shouldReload) {
          window.location.reload();
        }
      }

      function clearLegacyPreferences() {
        try {
          window.localStorage.removeItem("preferred-language");
        } catch {}

        try {
          window.sessionStorage.removeItem("preferred-language-session");
        } catch {}
      }

      function initializeTranslationToggle() {
        const buttons = document.querySelectorAll("[data-translate-button]");

        if (!buttons.length) {
          return;
        }

        buttons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement) || button.dataset.translateBound === "true") {
            return;
          }

          button.dataset.translateBound = "true";
          button.addEventListener("click", () => {
            const nextLanguage = button.dataset.translateButton === TARGET_LANGUAGE
              ? TARGET_LANGUAGE
              : SOURCE_LANGUAGE;
            setSessionLanguage(nextLanguage);
            applyLanguage(nextLanguage, { reload: true });
          });
        });
      }

      window.googleTranslateElementInit = () => {
        if (!(window.google && window.google.translate && window.google.translate.TranslateElement)) {
          return;
        }

        new window.google.translate.TranslateElement(
          {
            pageLanguage: SOURCE_LANGUAGE,
            includedLanguages: TARGET_LANGUAGE,
            autoDisplay: false
          },
          "google_translate_element"
        );
      };

      clearLegacyPreferences();
      const sessionLanguage = getSessionLanguage();
      const initialLanguage = sessionLanguage === TARGET_LANGUAGE ? TARGET_LANGUAGE : SOURCE_LANGUAGE;
      applyLanguage(initialLanguage);

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initializeTranslationToggle, { once: true });
      } else {
        initializeTranslationToggle();
      }
    </script>
    <script is:inline src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
  </body>
</html>

<style>
  body{
    top: 0 !important;
  }
  .translate-widget{
    position: absolute;
    inset: 0 auto auto 0;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }
  :global(.skiptranslate),
  :global(.goog-te-banner-frame){
    display: none !important;
  }
  :global(.notranslate){
    unicode-bidi: isolate;
  }
  .main{
    padding: 1.6rem 0 0;
  }
  .prose{
    padding: 1.4rem 1.4rem 1.6rem;
  }
  .prose :global(.card){
    padding: 1.2rem 1.2rem 1.25rem;
  }
  .prose{
    background: color-mix(in srgb, var(--surface) 86%, transparent);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  @media (max-width: 760px){
    .prose{ padding: 1.1rem 1rem 1.25rem; }
  }
</style>
